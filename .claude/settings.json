{
  "permissions": {
    "defaultMode": "acceptEdits",
    "additionalDirectories": [],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(git push:*)",
      "WebFetch",
      "WebSearch",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
